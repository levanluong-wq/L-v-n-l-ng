sin = input("Nhap so SIN (9 chu so): ")
check = int(sin[-1])
digits = list(map(int, sin[:-1]))[::-1]
s1 = 0
s2 = 0
for i in range(len(digits)):
    if i % 2 == 0:
        s1 += digits[i]
    else:
        t = digits[i] * 2
        s2 += t // 10 + t % 10
tong = s1 + s2 + check
if tong % 10 == 0:
    print("SIN hop le")
else:
    print("SIN khong hop le")
